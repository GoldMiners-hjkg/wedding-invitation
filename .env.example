# ── RSVP storage ─────────────────────────────────────────────────────────────
# auto     Pick postgres → supabase → sqlite → demo (default)
# postgres Recommended for HK/SG/Aliyun RDS — set DATABASE_URL
# supabase Supabase REST API (server-side only; guests never call Supabase)
# sqlite   Self-hosted VPS / Docker — file at SQLITE_PATH
# demo     Preview only — no persistence
RSVP_STORAGE=auto

# Postgres (Supabase direct connection, Neon, Aliyun RDS, etc.)
# Supabase: Project Settings → Database → Connection string (URI)
# Prefer region ap-southeast-1 (Singapore) for guests in mainland China
DATABASE_URL=postgresql://user:password@host:5432/postgres

# SQLite — self-hosted only (HK/SG VPS with persistent disk, Node 22+)
# File is stored at ./data/<name>
SQLITE_PATH=rsvp.db

# ── Supabase (optional if not using DATABASE_URL) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin page password
ADMIN_PASSWORD=choose-a-strong-passphrase

# Preview mode — accepts RSVPs but stores in memory only
DEMO_MODE=false
